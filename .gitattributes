# Normalize line endings: store LF in the repo, check out LF on every OS.
# This overrides each machine's core.autocrlf, so the team stays consistent
# without relying on per-developer git config.

# Default: auto-detect text files and force LF both in repo and on disk.
* text=auto eol=lf

# Explicit text files (avoids any chance of being misdetected as binary).
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.env       text eol=lf

# Windows-only scripts must keep CRLF or they break.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files: never touch line endings.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
