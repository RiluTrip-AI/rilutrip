# ============================================================================
# Purpose:           Edge Functions runtime environment variables (local dev).
# Consumer:          edge_runtime container — exposed to Deno code via
#                    Deno.env.get("VAR_NAME") inside supabase/functions/*.
# Read on:           Edge Function invocation.
# Cloud equivalent:  Supabase Dashboard → Edge Functions → Secrets
#                    (project: rkxowkdqkplsqhxivynl).
# After editing:     `docker restart supabase_edge_runtime_ChillTours` to
#                    pick up new values (or `supabase stop && supabase start`).
#
# NOT related to supabase/.env — they are PARALLEL files for different
# consumers, not an override pair (the .local suffix here does NOT follow the
# Next.js convention; both files are read independently for different purposes).
#
# Setup: copy this file to supabase/.env.local and fill in the real values.
# The real .env.local is gitignored (.gitignore: .env*.local) — never commit it.
# ============================================================================

# --- Internal gateway (must match project root .env.local API_GATEWAY_SECRET) ---
API_GATEWAY_SECRET=your-api-gateway-secret

# --- Vertex AI (Gemini) ---
# Used by: generate-itinerary, chat
VERTEX_API_KEY=your-vertex-api-key
ITINERARY_MODEL=gemini-3.5-flash
CHAT_MODEL=gemini-3.5-flash

# --- Google Maps server-side key ---
# Used by: optimize-route, resolve-places, _shared/place-resolver
# Note: this is the SERVER-side key (NOT the NEXT_PUBLIC_ one), may have
# different API restrictions in Google Cloud Console.
GOOGLE_MAPS_API_KEY=your-google-maps-server-key

# --- OpenRouteService (route optimization TSP solver) ---
# Used by: optimize-route
# Optional — if missing, falls back to greedy time-window solver.
ORS_API_KEY=your-ors-api-key
