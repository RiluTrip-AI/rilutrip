# ============================================================================
# Purpose:           Supabase local stack system configuration.
# Consumer:          Supabase CLI — substitutes env(...) references in
#                    supabase/config.toml when starting the local stack
#                    (Auth / Realtime / Storage containers).
# Read on:           `supabase start`
# Cloud equivalent:  Supabase Dashboard → Project Settings / Auth Providers.
# After editing:     `supabase stop && supabase start` to reload.
#
# NOT related to supabase/.env.local — they are PARALLEL files for different
# consumers, not an override pair (the .local suffix here does NOT follow the
# Next.js convention; both files are read independently for different purposes).
#
# Setup: copy this file to supabase/.env and fill in the real values.
# The real .env is gitignored (.gitignore: supabase/.env) — never commit it.
# ============================================================================

# --- Google OAuth (for [auth.external.google] in config.toml) ---
# Same OAuth Client used by the cloud Supabase project.
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Make sure http://127.0.0.1:54321/auth/v1/callback is in Authorized redirect URIs.
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOTRUE_EXTERNAL_GOOGLE_SECRET=your-google-oauth-client-secret
